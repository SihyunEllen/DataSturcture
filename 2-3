#include<stdio.h>
#include<stdlib.h>

int* prefixAverages1(int X[],int);
int* prefixAverages2(int X[],int);
int main() {

	int n,i;
	scanf("%d", &n);
	int* X = (int*)malloc(sizeof(int) * n);

	for (i = 0; i < n; i++) {
		scanf("%d", &X[i]);
	}

	int* a = prefixAverages1(X, n);
	int*b= prefixAverages1(X, n);

	for (i = 0; i < n; i++) printf("%d ", a[i]);
	printf("\n");
	for (i = 0; i < n; i++) printf("%d ", b[i]);

	free(X);
	free(a);
	free(b);

	return 0;
}


int* prefixAverages1(int X[],int n) {
    double sum = 0.0;
	int* A = (int*)malloc(sizeof(int) * n);
	for (int i = 0; i < n; i++) {
		sum = 0;
		for (int j = 0; j <=i; j++) {
			sum += X[j];
		}
		A[i] =(int)((sum / (i + 1))+0.5) ;
	}
	return A;
}
